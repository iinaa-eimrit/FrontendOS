{
  "name": "frontend-os",
  "version": "0.1.0",
  "private": true,
  "description": "FrontendOS — A Frontend Engineering Operating System",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*",
    "zones/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:e2e": "turbo test:e2e",
    "test:visual": "turbo test:visual",
    "clean": "turbo clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "storybook": "turbo storybook",
    "lighthouse": "turbo lighthouse",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.58.2",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "msw": "^2.12.13",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
