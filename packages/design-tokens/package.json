{
  "name": "@frontendos/design-tokens",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/tokens.css",
    "./scss": "./dist/tokens.scss",
    "./json": "./dist/tokens.json"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts && node scripts/generate.mjs",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@frontendos/ts-config": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "rimraf": "^5.0.0"
  }
}
